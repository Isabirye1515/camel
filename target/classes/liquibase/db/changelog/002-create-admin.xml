<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="002-create-admin" author="elia">

        <createTable tableName="admin">

            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true"
                             nullable="false"/>
            </column>

            <column name="aname" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="pword" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="uname" type="VARCHAR(100)">
                <constraints nullable="false"
                             unique="true"/>
            </column>

            <column name="role_id" type="INT"/>

            <column name="admin_id" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="lastupdated" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <addForeignKeyConstraint
                baseTableName="admin"
                baseColumnNames="role_id"
                referencedTableName="role"
                referencedColumnNames="id"
                constraintName="fk_admin_role"/>

    </changeSet>

</databaseChangeLog>