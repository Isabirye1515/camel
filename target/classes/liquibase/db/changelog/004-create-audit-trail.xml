<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004-create-audit-trail" author="elia">

        <createTable tableName="audit_trail">

            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true"
                             nullable="false"/>
            </column>

            <column name="created_on" type="DATE"/>

            <column name="updated_on" type="DATE"/>

            <column name="admin_id" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="table_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="action" type="VARCHAR(250)">
                <constraints nullable="false"/>
            </column>

            <column name="lastupdated" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <addForeignKeyConstraint
                baseTableName="audit_trail"
                baseColumnNames="admin_id"
                referencedTableName="admin"
                referencedColumnNames="id"
                constraintName="fk_audit_trail_admin"/>

    </changeSet>

</databaseChangeLog>